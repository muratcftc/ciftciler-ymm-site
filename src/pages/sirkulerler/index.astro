---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const sirkulerler = (await getCollection('sirkulerler')).sort(
	(a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<MainLayout title="Sirkülerler | Çiftçiler YMM">
	<main>
		<h1>Sirkülerler</h1>
		<p>Vergi uygulamalarına ilişkin bilgilendirme notları ve değerlendirmeler.</p>

		<section>
			{
				sirkulerler.map((entry) => (
					<article>
						<h2>
							<a href={`/sirkulerler/${entry.slug}`}>{entry.data.title}</a>
						</h2>
						<p>{entry.data.summary}</p>
						<p>
							Yayın Tarihi:{' '}
							<time datetime={entry.data.publishDate.toISOString()}>
								{entry.data.publishDate.toLocaleDateString('tr-TR')}
							</time>
						</p>
					</article>
				))
			}
		</section>
	</main>
</MainLayout>
